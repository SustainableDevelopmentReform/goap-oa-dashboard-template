{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Maritime Strategic Data",
  "type": "object",
  "required": ["currency", "lastUpdated", "strategic"],
  "properties": {
    "currency": { "type": "string", "minLength": 3 },
    "lastUpdated": { "type": "string", "format": "date" },
    "strategic": {
      "type": "object",
      "required": [
        "metrics",
        "ageDistribution",
        "depreciation",
        "composition",
        "workforce",
        "revenue"
      ],
      "properties": {
        "metrics": {
          "type": "object",
          "required": [
            "fleetValue",
            "fleetValuePerVessel",
            "fleetValueAsGdpPercent",
            "medianFleetAge",
            "totalRevenue",
            "crewWageCosts",
            "maintenanceCosts"
          ],
          "properties": {
            "fleetValue": { "type": "number", "minimum": 0 },
            "fleetValuePerVessel": { "type": "number", "minimum": 0 },
            "fleetValueAsGdpPercent": { "type": "number", "minimum": 0 },
            "medianFleetAge": { "type": "number", "minimum": 0 },
            "totalRevenue": { "type": "number", "minimum": 0 },
            "crewWageCosts": { "type": "number", "minimum": 0 },
            "maintenanceCosts": { "type": "number", "minimum": 0 }
          },
          "additionalProperties": false
        },
        "ageDistribution": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["years", "count"],
            "properties": {
              "years": { "type": "number", "minimum": 0 },
              "count": { "type": "integer", "minimum": 0 }
            },
            "additionalProperties": false
          }
        },
        "depreciation": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["year", "value"],
            "properties": {
              "year": { "type": "integer", "minimum": 1900 },
              "value": { "type": "number", "minimum": 0 }
            },
            "additionalProperties": false
          }
        },
        "composition": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["type", "count"],
            "properties": {
              "type": { "type": "string", "minLength": 1 },
              "count": { "type": "integer", "minimum": 0 }
            },
            "additionalProperties": false
          }
        },
        "workforce": {
          "type": "object",
          "required": ["low", "mid", "high"],
          "properties": {
            "low": { "type": "number", "minimum": 0 },
            "mid": { "type": "number", "minimum": 0 },
            "high": { "type": "number", "minimum": 0 }
          },
          "additionalProperties": false
        },
        "revenue": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["source", "value"],
            "properties": {
              "source": { "type": "string", "minLength": 1 },
              "value": { "type": "number", "minimum": 0 }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
