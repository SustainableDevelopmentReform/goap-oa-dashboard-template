{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Time Series Data",
  "type": "object",
  "required": ["startYear", "endYear", "ecosystems"],
  "properties": {
    "startYear": { "type": "integer" },
    "endYear": { "type": "integer" },
    "metadata": {
      "type": "object",
      "required": ["dataSource", "methodology"],
      "properties": {
        "dataSource": { "type": "string", "minLength": 1 },
        "methodology": { "type": "string", "minLength": 1 },
        "notes": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "ecosystems": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "displayName", "unit", "data"],
        "properties": {
          "name": { "type": "string" },
          "displayName": { "type": "string" },
          "unit": { "type": "string" },
          "data": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["year", "value", "confidence"],
              "properties": {
                "year": { "type": "integer" },
                "value": { "type": "number" },
                "confidence": {
                  "type": "string",
                  "enum": ["low", "medium", "high"]
                }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
