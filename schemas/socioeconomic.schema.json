{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Socioeconomic Dashboard Data",
  "type": "object",
  "required": ["lastUpdated", "atollId", "atollName", "indicators", "atollAverages", "islands"],
  "properties": {
    "lastUpdated": { "type": "string", "format": "date" },
    "atollId": { "type": "string", "minLength": 1 },
    "atollName": { "type": "string", "minLength": 1 },
    "indicators": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/socialIndicatorDefinition" }
    },
    "atollAverages": { "$ref": "#/$defs/socialMetricsMap" },
    "islands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "atollId", "population", "metrics", "socioeconomic"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "atollId": { "type": "string", "minLength": 1 },
          "population": { "type": "number", "minimum": 0 },
          "metrics": { "$ref": "#/$defs/socialMetricsMap" },
          "populationDistribution": {
            "anyOf": [
              { "$ref": "#/$defs/populationDistribution" },
              { "type": "null" }
            ]
          },
          "socioeconomic": { "$ref": "#/$defs/socioeconomicProfile" }
        },
        "additionalProperties": false
      }
    },
    "notes": { "type": "string" }
  },
  "$defs": {
    "socialTierLabels": {
      "type": "object",
      "required": ["low", "moderate", "high"],
      "properties": {
        "low": { "type": "string" },
        "moderate": { "type": "string" },
        "high": { "type": "string" }
      },
      "additionalProperties": false
    },
    "socialIndicatorDefinition": {
      "type": "object",
      "required": ["id", "label", "description", "icon", "unit"],
      "properties": {
        "id": {
          "type": "string",
          "enum": [
            "fishingIncomeDependency",
            "foodSecurityDependence",
            "stormSurgeExposure",
            "tourismEmploymentShare",
            "youthPopulationShare",
            "populationSize",
            "weeklyFishSeafoodSpend",
            "coastalDamageExposure"
          ]
        },
        "label": { "type": "string" },
        "shortLabel": { "type": ["string", "null"] },
        "description": { "type": "string" },
        "icon": {
          "type": "string",
          "enum": ["boat", "meal", "wave", "tourism", "youth", "population", "currency", "damage"]
        },
        "unit": {
          "type": "string",
          "enum": ["percentage", "number", "currency"]
        },
        "tierLabels": { "$ref": "#/$defs/socialTierLabels" }
      },
      "additionalProperties": false
    },
    "socialMetric": {
      "type": "object",
      "required": ["value", "tier"],
      "properties": {
        "value": { "type": ["number", "null"] },
        "tier": { "type": ["string", "null"], "enum": ["low", "moderate", "high", null] },
        "iconCount": { "type": ["integer", "null"], "minimum": 1, "maximum": 3 },
        "percentile": { "type": ["number", "null"], "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": false
    },
    "socialMetricsMap": {
      "type": "object",
      "required": [
        "fishingIncomeDependency",
        "foodSecurityDependence",
        "stormSurgeExposure",
        "tourismEmploymentShare",
        "youthPopulationShare",
        "populationSize",
        "weeklyFishSeafoodSpend",
        "coastalDamageExposure"
      ],
      "properties": {
        "fishingIncomeDependency": { "$ref": "#/$defs/socialMetric" },
        "foodSecurityDependence": { "$ref": "#/$defs/socialMetric" },
        "stormSurgeExposure": { "$ref": "#/$defs/socialMetric" },
        "tourismEmploymentShare": { "$ref": "#/$defs/socialMetric" },
        "youthPopulationShare": { "$ref": "#/$defs/socialMetric" },
        "populationSize": { "$ref": "#/$defs/socialMetric" },
        "weeklyFishSeafoodSpend": { "$ref": "#/$defs/socialMetric" },
        "coastalDamageExposure": { "$ref": "#/$defs/socialMetric" }
      },
      "additionalProperties": false
    },
    "populationDistribution": {
      "type": "object",
      "required": ["total", "males", "females", "ageDistribution"],
      "properties": {
        "total": { "type": "number", "minimum": 0 },
        "males": { "type": ["number", "null"], "minimum": 0 },
        "females": { "type": ["number", "null"], "minimum": 0 },
        "ageDistribution": {
          "type": "object",
          "required": ["age0to14", "age15to64", "age65plus"],
          "properties": {
            "age0to14": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
            "age15to64": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
            "age65plus": { "type": ["number", "null"], "minimum": 0, "maximum": 100 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "socioeconomicProfile": {
      "type": "object",
      "required": [
        "totalPopulation",
        "households",
        "femaleShare",
        "dependencyRatio",
        "disabilityShare",
        "unemploymentShare",
        "tourismWorkers",
        "tourismShare",
        "fishingHouseholds",
        "oceanResourcesShare"
      ],
      "properties": {
        "totalPopulation": { "type": ["number", "null"], "minimum": 0 },
        "households": { "type": ["number", "null"], "minimum": 0 },
        "femaleShare": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
        "dependencyRatio": { "type": ["number", "null"], "minimum": 0 },
        "disabilityShare": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
        "unemploymentShare": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
        "tourismWorkers": { "type": ["number", "null"], "minimum": 0 },
        "tourismShare": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
        "fishingHouseholds": { "type": ["number", "null"], "minimum": 0 },
        "oceanResourcesShare": { "type": ["number", "null"], "minimum": 0, "maximum": 100 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
