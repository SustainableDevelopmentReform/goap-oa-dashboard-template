{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Spatial Configuration",
  "type": "object",
  "required": ["mapConfig", "boundaries", "locations", "geeApp", "legend"],
  "properties": {
    "mapConfig": {
      "type": "object",
      "required": ["center", "defaultZoom", "maxZoom", "minZoom", "baseMapStyle"],
      "properties": {
        "center": {
          "type": "object",
          "required": ["latitude", "longitude"],
          "properties": {
            "latitude": { "type": "number", "minimum": -90, "maximum": 90 },
            "longitude": { "type": "number", "minimum": -180, "maximum": 180 }
          },
          "additionalProperties": false
        },
        "defaultZoom": { "type": "number" },
        "maxZoom": { "type": "number" },
        "minZoom": { "type": "number" },
        "baseMapStyle": { "type": "string" }
      },
      "additionalProperties": false
    },
    "boundaries": {
      "type": "object",
      "required": ["national", "subnational"],
      "properties": {
        "national": {
          "type": "object",
          "required": ["type", "geometry"],
          "properties": {
            "type": { "const": "Feature" },
            "geometry": {
              "type": "object",
              "required": ["type", "coordinates"],
              "properties": {
                "type": {
                  "type": "string",
                  "enum": ["Polygon", "MultiPolygon"]
                },
                "coordinates": { "type": "array" }
              }
            },
            "properties": { "type": "object" }
          }
        },
        "subnational": {
          "type": "object",
          "required": ["type", "features"],
          "properties": {
            "type": { "const": "FeatureCollection" },
            "features": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["type", "geometry", "properties"],
                "properties": {
                  "type": { "const": "Feature" },
                  "geometry": {
                    "type": "object",
                    "required": ["type", "coordinates"],
                    "properties": {
                      "type": {
                        "type": "string",
                        "enum": ["Polygon", "MultiPolygon"]
                      },
                      "coordinates": { "type": "array" }
                    }
                  },
                  "properties": { "type": "object" }
                }
              }
            }
          }
        }
      }
    },
    "locations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "type", "coordinates"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "type": { "type": "string" },
          "description": { "type": ["string", "null"] },
          "coordinates": {
            "type": "object",
            "required": ["latitude", "longitude"],
            "properties": {
              "latitude": { "type": "number", "minimum": -90, "maximum": 90 },
              "longitude": { "type": "number", "minimum": -180, "maximum": 180 }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    },
    "geeApp": {
      "type": "object",
      "required": ["url", "title"],
      "properties": {
        "url": { "type": "string", "format": "uri" },
        "title": { "type": "string" },
        "description": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "legend": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["ecosystem", "color", "label"],
        "properties": {
          "ecosystem": { "type": "string" },
          "color": { "type": "string" },
          "label": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "ecosystemRasters": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "label", "source", "color"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 1 },
          "source": { "type": "string", "format": "uri" },
          "color": { "type": "string" },
          "value": { "type": ["number", "null"] },
          "opacity": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
          "description": { "type": ["string", "null"] }
        },
        "additionalProperties": false
      }
    },
    "overlays": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "type", "url"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "type": { "type": "string", "enum": ["geojson", "vector"] },
          "url": { "type": "string", "format": "uri" },
          "fillColor": { "type": ["string", "null"] },
          "outlineColor": { "type": ["string", "null"] },
          "opacity": { "type": ["number", "null"], "minimum": 0, "maximum": 1 }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
