{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Maritime Crew",
  "type": "object",
  "required": ["crew", "rankDistribution", "nationalityBreakdown", "metadata"],
  "properties": {
    "crew": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "rank", "nationality", "status"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "rank": { "type": "string", "minLength": 1 },
          "nationality": { "type": "string", "minLength": 1 },
          "certifications": {
            "type": "array",
            "items": { "type": "string" }
          },
          "status": {
            "type": "string",
            "enum": ["active", "inactive"]
          }
        },
        "additionalProperties": false
      }
    },
    "rankDistribution": {
      "type": "object",
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    },
    "nationalityBreakdown": {
      "type": "object",
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    },
    "metadata": {
      "type": "object",
      "required": ["totalCrewCount", "lastUpdated", "source"],
      "properties": {
        "totalCrewCount": { "type": "integer", "minimum": 0 },
        "lastUpdated": { "type": "string", "format": "date" },
        "source": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
