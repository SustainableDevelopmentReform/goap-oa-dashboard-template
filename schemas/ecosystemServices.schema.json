{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Ecosystem Services",
  "type": "object",
  "required": ["ecosystems"],
  "properties": {
    "ecosystems": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["ecosystem", "ecosystemLabel", "metrics"],
        "properties": {
          "ecosystem": { "type": "string", "minLength": 1 },
          "ecosystemLabel": { "type": "string", "minLength": 1 },
          "metrics": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["id", "label", "unit", "values"],
              "properties": {
                "id": { "type": "string", "minLength": 1 },
                "label": { "type": "string", "minLength": 1 },
                "unit": { "type": "string", "minLength": 1 },
                "values": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "object",
                    "required": ["year", "value"],
                    "properties": {
                      "year": { "type": "integer", "minimum": 1900 },
                      "value": { "type": "number", "minimum": 0 }
                    },
                    "additionalProperties": false
                  }
                }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "dataSource": { "type": ["string", "null"] },
        "methodology": { "type": ["string", "null"] },
        "notes": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
